# IKVCS 的 .gitignore
# 仅保留源码/配置；忽略生成物、敏感信息和存储数据。

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.tox/
.coverage
htmlcov/
test-results/
*.cover
*.log

# 虚拟环境
venv/
.venv/
backend/venv/

# Node/Vite
node_modules/
dist/
build/
.vite/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# 环境变量/密钥
.env*
*.key
*.pem
*.pfx
*.crt
*.cer
*.p12
*.keystore

# 存储/上传
backend/storage/**
!backend/storage/**/.gitkeep
backend/uploads/
backend/tmp/
backend/logs/

# 数据库导出
*.sql
**/*.sql

# 项目文档（生成物）
docs/

# 工具
.kiro/
.serena/
.cursorrules

# 外部子项目
mcp-feedback-enhanced-main/

# 测试（可选）
backend/test/
backend/pytest.ini

# Docker/本地数据
docker/
docker-compose.yml
.cursor/commands/basic.md
.cursor/commands/thesis-draft.md
.cursor/rules/basic.mdc
